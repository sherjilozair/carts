pico-8 cartridge // http://www.pico-8.com
version 30
__lua__
-- Player Code

-- TODO

left = ⬅️
up = ⬆️
right = ➡️
down = ⬇️
jump = ▥
action = 🐱

max_speed = 90
run_accel = 1000
run_reduce = 400
gravity = 900
jump_speed = -180
jump_boost = 40

function _init()
	player = {x = 64, y = 64, vx = 0, vy = 0}
	player.spr = 1
end

function _update60()
	dt = 1 / 60
	local inputx = 0
	if btn(left) then
		inputx = -1
	elseif btn(right) then
		inputx = 1
	end

	is_ground = player.y > 70

	if abs(max_speed * inputx) > abs(player.vx) then
		accel = run_accel
	else
		accel = run_reduce
	end
	player.vx = appr(player.vx, max_speed * inputx, accel * dt)
	dbg = 'add variable jumping'
	if is_ground then
		player.vy = 0
		if btnp(4) then
			player.vy = jump_speed
			if inputx ~= 0 then
				player.vx = player.vx + inputx * jump_boost
			end
		end
	else
		player.vy = player.vy + gravity * dt
	end

	player.x = player.x + player.vx * dt
	player.y = player.y + player.vy * dt
end

function _draw()
	cls()
 	spr(player.spr,player.x,player.y)
	 print(dbg,x,y)
end


function appr(val, target, amount)
	return val > target 
     and max(val - amount, target) 
     or min(val + amount, target)
end

